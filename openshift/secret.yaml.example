# Template only — DO NOT commit real credentials.
# Apply with `oc create secret` instead so values stay out of git:
#
#   oc create secret generic fastapi-scraper-env \
#     --from-literal=DATABASE_URL='postgresql+asyncpg://USER:PASS@HOST:5432/DBNAME' \
#     --from-literal=CORS_ALLOW_ORIGINS='https://gatekeeper.example.com' \
#     --from-literal=APP_USERNAME='...' \
#     --from-literal=APP_PASSWORD='...'
#
# APP_USERNAME / APP_PASSWORD are only required if config.json's `login` block
# is in use. Omit them otherwise.

apiVersion: v1
kind: Secret
metadata:
  name: fastapi-scraper-env
  labels:
    app: fastapi-scraper
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://USER:PASS@HOST:5432/DBNAME"
  CORS_ALLOW_ORIGINS: "https://gatekeeper.example.com"
  # APP_USERNAME: "..."
  # APP_PASSWORD: "..."
